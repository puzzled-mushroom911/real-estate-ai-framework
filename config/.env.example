# ============================================================
# Real Estate Agent AI Framework - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Agent Identity ---
AGENT_NAME="Your Name"
AGENT_PHONE="(555) 123-4567"
AGENT_EMAIL="you@yourbrokerage.com"
AGENT_WEBSITE="https://www.yourbrokerage.com"
AGENT_BROKERAGE="Your Brokerage Name"
AGENT_CITY="Your City"
AGENT_STATE="FL"

# --- CRM (GoHighLevel) ---
# Get your API key from GHL Settings > Business Profile > API Keys
CRM_API_KEY="pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
CRM_LOCATION_ID="your_location_id"
CRM_ENDPOINT="https://services.leadconnectorhq.com/mcp/"

# --- Anthropic (for AI-enhanced content generation) ---
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"

# --- Python ---
# If your Python 3.10+ isn't the default, set the path:
# PYTHON_PATH="/usr/local/bin/python3"
